{
  "name": "inknote",
  "version": "0.1.0",
  "description": "Digital ink note-taking app for Windows pen/touch devices — pressure-sensitive drawing, PDF annotation, on-device OCR",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "author": "Benjamín Taito",
  "repository": {
    "type": "git",
    "url": "https://github.com/benjamintaito/inknote.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package": "npm run build && electron-builder",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.577.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2"
  }
